{
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "python .claude/hooks/guard_env.py"
                    }
                ]
            }
        ]
    },
    "permissions": {
        "allow": [
            "Bash(uv *)",
            "Bash(python *)",
            "Bash(pip *)",
            "Bash(ls *)",
            "Bash(cat src/**)",
            "Bash(cat output/**)",
            "Read(src/**)",
            "Read(output/**)",
            "Read(docs/**)",
            "Read(.env.example)"
        ],
        "deny": [
            "Read(.env)",
            "Bash(rm -rf *)"
        ]
    }
}